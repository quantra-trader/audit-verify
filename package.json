{
  "name": "@quantra/audit-verify",
  "version": "1.1.1",
  "description": "Offline cryptographic verifier for Quantra Sealed™ Audit Pack exports. Verify trade attestation chains without trusting Quantra. Zero dependencies.",
  "type": "module",
  "main": "./lib/sealedVerifier.mjs",
  "bin": {
    "quantra-audit-verify": "./verify.mjs"
  },
  "exports": {
    ".": "./lib/sealedVerifier.mjs",
    "./canonical": "./lib/canonicalHash.mjs"
  },
  "scripts": {
    "test": "node --test tests/canonicalHash.test.mjs tests/verifier.test.mjs",
    "verify": "node verify.mjs",
    "generate-fixtures": "node tests/generate-fixtures.mjs"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "lib/",
    "verify.mjs",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "keywords": [
    "audit",
    "verification",
    "trading",
    "hash-chain",
    "sealed",
    "quantra",
    "attestation",
    "tamper-proof",
    "trade-record",
    "cryptographic",
    "offline-verifier"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/quantra-trader/audit-verify.git"
  },
  "homepage": "https://github.com/quantra-trader/audit-verify",
  "bugs": {
    "url": "https://github.com/quantra-trader/audit-verify/issues"
  },
  "author": "Quantra Tech, S.L.U.",
  "license": "MIT"
}
